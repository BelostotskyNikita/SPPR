@model ListModel<ClothingItem>
@using Microsoft.AspNetCore.Http.Extensions

@{
    ViewData["Title"] = "Каталог товаров";
    var request = ViewContext.HttpContext.Request;
    var returnUrl = request.Path + request.QueryString.ToUriComponent();
    var categories = ViewData["Categories"] as List<Category> ?? new List<Category>();
    var currentCategory = ViewData["CurrentCategory"] as string ?? "Все категории";
    var currentCategoryNormalizedName = ViewData["CurrentCategoryNormalizedName"] as string;
}

<h1>Каталог товаров</h1>

<!-- выбор категории -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Фильтр по категориям</h5>
            </div>
            <div class="card-body">
                <ul class="nav flex-column">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle btn btn-outline-primary w-100 text-start"
                           data-bs-toggle="dropdown"
                           href="#"
                           role="button"
                           aria-expanded="false">
                            @currentCategory
                        </a>
                        <ul class="dropdown-menu w-100">
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Product"
                                   asp-route-category=@null
                                   asp-route-pageNo="1">
                                    Все категории
                                </a>
                            </li>
                            @foreach (var item in categories)
                            {
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Product"
                                       asp-route-category="@item.NormalizedName"
                                       asp-route-pageNo="1">
                                        @item.Name
                                    </a>
                                </li>
                            }
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div><!-- выбор категории -->

@if (Model == null || !Model.Items.Any())
{
    <div class="alert alert-info">
        <h4>Товары не найдены</h4>
        <p>В категории "@currentCategory" пока нет товаров.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model.Items)
        {
            <div class="col">
                <div class="card h-100">
                    @if (!string.IsNullOrEmpty(item?.ImagePath))
                    {
                        <img src="@item.ImagePath" class="card-img-top" alt="@item?.Name" style="height: 200px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                            <span class="text-muted">Нет изображения</span>
                        </div>
                    }

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@(item?.Name ?? "Не указано")</h5>
                        <p class="card-text flex-grow-1">@(item?.Description ?? "Описание отсутствует")</p>

                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted">Размер: @(item?.Size ?? "Не указан")</span>
                                <span class="text-muted">Цвет: @(item?.Color ?? "Не указан")</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <strong class="h5 mb-0">@(item?.Price.ToString("N2") ?? "0") руб.</strong>
                                <small class="text-muted">@(item?.Material ?? "Не указан")</small>
                            </div>

                            <form method="post" asp-controller="Cart" asp-action="Add">
                                <input type="hidden" name="id" value="@item?.Id" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-cart-plus"></i> Добавить в корзину
                                </button>
                            </form>
                        </div>
                    </div>

                    <div class="card-footer">
                        <small class="text-muted">Категория: @(item?.Category?.Name ?? "Без категории")</small>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link"
                           asp-controller="Product"
                           asp-route-category="@currentCategoryNormalizedName"
                           asp-route-pageNo="@(Model.CurrentPage - 1)">
                            Назад
                        </a>
                    </li>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-controller="Product"
                           asp-route-category="@currentCategoryNormalizedName"
                           asp-route-pageNo="@i">@i</a>
                    </li>
                }

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link"
                           asp-controller="Product"
                           asp-route-category="@currentCategoryNormalizedName"
                           asp-route-pageNo="@(Model.CurrentPage + 1)">
                            Вперед
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
}