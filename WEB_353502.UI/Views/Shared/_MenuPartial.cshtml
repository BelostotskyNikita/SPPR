@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLower() ?? string.Empty;
    var area = ViewContext.RouteData.Values["area"]?.ToString()?.ToLower() ?? string.Empty;
}

<!-- меню сайта -->
<a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">LabsV03</a>
<div class="navbar-nav">
    <a class="nav-item nav-link @(controller == "home" && area == "" ? "active" : "")"
       asp-area="" asp-controller="Home" asp-action="Index">Лб 1</a>
    <a class="nav-item nav-link @(controller == "product" ? "active" : "")"
       asp-area="" asp-controller="Product" asp-action="Index">Каталог</a>
    <a class="nav-item nav-link @(area == "admin" ? "active" : "")"
       asp-area="Admin" asp-page="/Index">Администрирование</a>
</div>
<!-- меню сайта - конец -->